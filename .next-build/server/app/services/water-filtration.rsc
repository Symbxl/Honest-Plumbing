f:T493,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Do I need a water filtration system on Murfreesboro city water?","acceptedAnswer":{"@type":"Answer","text":"City water in Murfreesboro and the surrounding municipalities is generally safe to drink. Many homeowners still want carbon filtration to remove the chlorine taste, and a softener if the hardness is causing scale on fixtures and appliances. We'll be honest about whether your specific home actually benefits."}},{"@type":"Question","name":"What about well water?","acceptedAnswer":{"@type":"Answer","text":"Well water often needs more — sediment filtration, an iron filter, sometimes a UV stage. We test the well water and design the system around what it actually contains rather than selling a generic package."}},{"@type":"Question","name":"How often does a whole-house system need service?","acceptedAnswer":{"@type":"Answer","text":"Cartridge or media changes vary by system, water quality, and household use — typically every 6–12 months for cartridges, every 4–10 years for tank media. We'll set a service schedule that matches your specific install."}}]}7:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.honestplumbingtn.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Services\",\"item\":\"https://www.honestplumbingtn.com/services\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Whole-House Water Filtration\",\"item\":\"https://www.honestplumbingtn.com/services/water-filtration\"}]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$f"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Service\",\"name\":\"Whole-House Water Filtration\",\"description\":\"Whole-house water filtration systems, repairs, and selection consulting in Murfreesboro and Middle Tennessee. Honest advice about what your water actually needs — and what it doesn't.\",\"serviceType\":\"Whole-House Water Filtration\",\"url\":\"https://www.honestplumbingtn.com/services/water-filtration\",\"provider\":{\"@id\":\"https://www.honestplumbingtn.com#business\"},\"areaServed\":[{\"@type\":\"City\",\"name\":\"Murfreesboro\"},{\"@type\":\"City\",\"name\":\"Smyrna\"},{\"@type\":\"City\",\"name\":\"La Vergne\"},{\"@type\":\"City\",\"name\":\"Nolensville\"},{\"@type\":\"City\",\"name\":\"Brentwood\"},{\"@type\":\"City\",\"name\":\"Franklin\"}]}"}}],["$","article",null,{"children":[["$","section",null,{"className":"relative h-[260px] sm:h-[340px] lg:h-[420px] overflow-hidden bg-forest-deep","children":[["$","$L4",null,{"src":"/images/owner-2.jpg","alt":"Water filtration system installation by Honest Plumbing in Middle Tennessee","fill":true,"priority":true,"sizes":"100vw","className":"object-cover opacity-80"}],["$","div",null,{"aria-hidden":true,"className":"absolute inset-0 bg-gradient-to-t from-forest-deep/70 via-forest-deep/30 to-transparent"}]]}],["$","section",null,{"className":"py-16 lg:py-24 border-b border-ink/10","children":["$","div",null,{"className":"max-w-7xl mx-auto px-6 lg:px-12 grid lg:grid-cols-12 gap-10 lg:gap-16","children":[["$","div",null,{"className":"lg:col-span-7","children":[["$","nav",null,{"aria-label":"Breadcrumb","className":"text-sm text-ink-muted mb-6","children":["$","ol",null,{"className":"flex items-center gap-2","children":[["$","li",null,{"children":["$","$L3",null,{"href":"/","className":"hover:text-forest","children":"Home"}]}],["$","li",null,{"aria-hidden":true,"children":"/"}],["$","li",null,{"children":["$","$L3",null,{"href":"/services","className":"hover:text-forest","children":"Services"}]}],["$","li",null,{"aria-hidden":true,"children":"/"}],["$","li",null,{"className":"text-ink","children":"Water Filtration"}]]}]}],["$","p",null,{"className":"eyebrow mb-4","children":"Service"}],["$","h1",null,{"className":"font-display text-4xl sm:text-5xl lg:text-6xl leading-[1.05] text-ink mb-6","children":["Whole-House Water Filtration"," ",["$","span",null,{"className":"italic text-forest","children":"in Middle Tennessee"}]]}],["$","p",null,{"className":"font-display italic text-2xl text-ink-soft mb-7","children":"Cleaner water at every tap — sized for what your water actually needs."}],["$","p",null,{"className":"text-lg text-ink-muted leading-relaxed","children":"Whole-house water filtration is one of the easiest places to overspend if you don't know what's actually in your water. We test, recommend the right system for your specific supply, and install whole-house filtration that does what it says it will. We also repair and service existing filtration systems even if we didn't install them."}]]}],["$","div",null,{"className":"lg:col-span-5","children":["$","$L10",null,{"defaultService":"water-filtration"}]}]]}]}],["$","section",null,{"className":"py-16 lg:py-24","children":["$","div",null,{"className":"max-w-3xl mx-auto px-6","children":["$","div",null,{"className":"prose-editorial","children":[["$","div","Selection: what your water actually needs",{"children":[["$","h2",null,{"children":"Selection: what your water actually needs"}],["$","p",null,{"children":"Middle Tennessee city water is generally clean but moderately hard, and well water in the surrounding rural areas can include iron, sulfur, sediment, and other concerns that municipal water doesn't have. The right system depends on what's actually in your supply — a sediment filter, a softener, an iron filter, a carbon block for taste and chlorine, or a reverse-osmosis stage at the kitchen tap are all different problems with different solutions. We test first, then recommend, then quote. Honest consultation is part of the job."}]]}],["$","div","Whole-house installation",{"children":[["$","h2",null,{"children":"Whole-house installation"}],["$","p",null,{"children":"A whole-house system installs at the point of entry where the main supply enters the home, so every tap and every appliance benefits — softer water for the water heater and dishwasher, cleaner water for showers and laundry, better-tasting water at the kitchen sink. We size the system for your home's flow rate so pressure isn't compromised, and we install with proper bypass valves so future service is straightforward."}]]}],["$","div","Repairs and service",{"children":[["$","h2",null,{"children":"Repairs and service"}],["$","p",null,{"children":"Filtration systems need periodic media replacement, cartridge changes, and occasional valve service. We service systems from every major manufacturer and can repair or rebuild older units whenever that's the more sensible choice than replacement."}]]}]]}]}]}],["$","section",null,{"className":"bg-bone-100/60 border-y border-ink/10 py-16 lg:py-24","children":["$","div",null,{"className":"max-w-3xl mx-auto px-6","children":[["$","p",null,{"className":"eyebrow mb-3","children":"Common questions"}],["$","h2",null,{"className":"font-display text-3xl lg:text-4xl text-ink mb-10 leading-tight","children":["Frequently asked about ","water filtration"," in Middle Tennessee."]}],["$","dl",null,{"className":"space-y-6","children":[["$","div","Do I need a water filtration system on Murfreesboro city water?",{"className":"card-press p-6","children":[["$","dt",null,{"className":"font-display text-xl text-ink mb-3","children":"Do I need a water filtration system on Murfreesboro city water?"}],["$","dd",null,{"className":"text-ink-muted leading-relaxed","children":"City water in Murfreesboro and the surrounding municipalities is generally safe to drink. Many homeowners still want carbon filtration to remove the chlorine taste, and a softener if the hardness is causing scale on fixtures and appliances. We'll be honest about whether your specific home actually benefits."}]]}],["$","div","What about well water?",{"className":"card-press p-6","children":[["$","dt",null,{"className":"font-display text-xl text-ink mb-3","children":"What about well water?"}],["$","dd",null,{"className":"text-ink-muted leading-relaxed","children":"Well water often needs more — sediment filtration, an iron filter, sometimes a UV stage. We test the well water and design the system around what it actually contains rather than selling a generic package."}]]}],["$","div","How often does a whole-house system need service?",{"className":"card-press p-6","children":[["$","dt",null,{"className":"font-display text-xl text-ink mb-3","children":"How often does a whole-house system need service?"}],["$","dd",null,{"className":"text-ink-muted leading-relaxed","children":"Cartridge or media changes vary by system, water quality, and household use — typically every 6–12 months for cartridges, every 4–10 years for tank media. We'll set a service schedule that matches your specific install."}]]}]]}]]}]}],["$","section",null,{"className":"py-16 lg:py-24","children":["$","div",null,{"className":"max-w-7xl mx-auto px-6 lg:px-12","children":[["$","div",null,{"className":"max-w-2xl mb-10","children":[["$","p",null,{"className":"eyebrow mb-3","children":"Service areas"}],["$","h2",null,{"className":"font-display text-3xl lg:text-4xl text-ink leading-tight","children":["We provide ","water filtration"," across these Middle Tennessee areas:"]}]]}],["$","ul",null,{"className":"grid sm:grid-cols-2 md:grid-cols-3 gap-3","children":[["$","li","murfreesboro",{"children":["$","$L3",null,{"href":"/areas/murfreesboro","className":"block py-3 px-4 border border-ink/10 hover:border-forest hover:bg-bone-100/50 transition-colors","children":[["$","span",null,{"className":"font-semibold text-ink","children":"Murfreesboro"}],["$","span",null,{"className":"block text-xs text-ink-muted mt-0.5","children":"Rutherford County, TN"}]]}]}],["$","li","smyrna",{"children":["$","$L3",null,{"href":"/areas/smyrna","cla