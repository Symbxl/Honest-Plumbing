7:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.honestplumbingtn.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Services\",\"item\":\"https://www.honestplumbingtn.com/services\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Water & Sewer Repipes\",\"item\":\"https://www.honestplumbingtn.com/services/water-sewer-repipes\"}]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Do I need a whole-home repipe or just a section?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"If you've had two or more pinhole leaks in the same year, or pressure is dropping at multiple fixtures, a full repipe usually makes more financial sense than chasing leaks. We'll diagnose honestly — spot repair when it's the right answer, full repipe only when it actually is.\"}},{\"@type\":\"Question\",\"name\":\"How long does a repipe take?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"A residential supply repipe is typically 2–4 days depending on the size of the home and access. Sewer line replacements run 1–3 days. We minimize the time your water is off.\"}},{\"@type\":\"Question\",\"name\":\"Is the work permitted and inspected?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes — every repipe is pulled on a permit, inspected by the local jurisdiction, and we don't ask for final payment until the inspection is signed off.\"}}]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Service\",\"name\":\"Water & Sewer Repipes\",\"description\":\"Whole-home water repipes and sewer line replacement in Murfreesboro and Middle Tennessee. Removal and installation of supply piping and sewer piping. Permitted, inspected, and warrantied.\",\"serviceType\":\"Water & Sewer Repipes\",\"url\":\"https://www.honestplumbingtn.com/services/water-sewer-repipes\",\"provider\":{\"@id\":\"https://www.honestplumbingtn.com#business\"},\"areaServed\":[{\"@type\":\"City\",\"name\":\"Murfreesboro\"},{\"@type\":\"City\",\"name\":\"Smyrna\"},{\"@type\":\"City\",\"name\":\"La Vergne\"},{\"@type\":\"City\",\"name\":\"Nolensville\"},{\"@type\":\"City\",\"name\":\"Brentwood\"},{\"@type\":\"City\",\"name\":\"Franklin\"}]}"}}],["$","article",null,{"children":[["$","section",null,{"className":"relative h-[260px] sm:h-[340px] lg:h-[420px] overflow-hidden bg-forest-deep","children":[["$","$L4",null,{"src":"/images/expertise-badge.png","alt":"Water and sewer repipe project by Honest Plumbing in Middle Tennessee","fill":true,"priority":true,"sizes":"100vw","className":"object-cover opacity-80"}],["$","div",null,{"aria-hidden":true,"className":"absolute inset-0 bg-gradient-to-t from-forest-deep/70 via-forest-deep/30 to-transparent"}]]}],["$","section",null,{"className":"py-16 lg:py-24 border-b border-ink/10","children":["$","div",null,{"className":"max-w-7xl mx-auto px-6 lg:px-12 grid lg:grid-cols-12 gap-10 lg:gap-16","children":[["$","div",null,{"className":"lg:col-span-7","children":[["$","nav",null,{"aria-label":"Breadcrumb","className":"text-sm text-ink-muted mb-6","children":["$","ol",null,{"className":"flex items-center gap-2","children":[["$","li",null,{"children":["$","$L3",null,{"href":"/","className":"hover:text-forest","children":"Home"}]}],["$","li",null,{"aria-hidden":true,"children":"/"}],["$","li",null,{"children":["$","$L3",null,{"href":"/services","className":"hover:text-forest","children":"Services"}]}],["$","li",null,{"aria-hidden":true,"children":"/"}],["$","li",null,{"className":"text-ink","children":"Water & Sewer Repipes"}]]}]}],["$","p",null,{"className":"eyebrow mb-4","children":"Service"}],["$","h1",null,{"className":"font-display text-4xl sm:text-5xl lg:text-6xl leading-[1.05] text-ink mb-6","children":["Water & Sewer Repipes"," ",["$","span",null,{"className":"italic text-forest","children":"in Middle Tennessee"}]]}],["$","p",null,{"className":"font-display italic text-2xl text-ink-soft mb-7","children":"Whole-home repipes. Permitted, inspected, warrantied."}],["$","p",null,{"className":"text-lg text-ink-muted leading-relaxed","children":"When water supply pipes have corroded, or a sewer line has failed and a spot repair isn't going to hold, the right answer is a repipe. We remove old supply and sewer piping and install new piping to current code across Murfreesboro and the surrounding Middle Tennessee area. Every repipe is permitted, inspected, and warrantied."}]]}],["$","div",null,{"className":"lg:col-span-5","children":["$","$Lf",null,{"defaultService":"water-sewer-repipes"}]}]]}]}],["$","section",null,{"className":"py-16 lg:py-24","children":["$","div",null,{"className":"max-w-3xl mx-auto px-6","children":["$","div",null,{"className":"prose-editorial","children":[["$","div","Water supply repipes",{"children":[["$","h2",null,{"children":"Water supply repipes"}],["$","p",null,{"children":"Older homes with galvanized or corroded copper supply lines often share a symptom: hot water that runs but slowly, low pressure throughout the house, and discolored water at the fixtures. A repipe with PEX or new copper restores full flow and stops the recurring leak problem at the joints. We remove the old piping, install new lines through the existing wall and crawlspace runs where possible, and pressure-test before patching and finishing."}]]}],["$","div","Sewer repipes",{"children":[["$","h2",null,{"children":"Sewer repipes"}],["$","p",null,{"children":"When a sewer lateral has multiple failures, recurring back-ups, or is collapsed in sections, repeated cleaning and spot repair stop being the right answer. Sewer repipe replaces the line end-to-end — from the house tie-in to the main — and the new line is warrantied. We use trenchless methods where the line path allows, and traditional open-trench excavation where the geometry of the property makes trenchless the wrong choice."}]]}],["$","div","Permits, inspections, and warranty",{"children":[["$","h2",null,{"children":"Permits, inspections, and warranty"}],["$","p",null,{"children":"Every repipe we do is pulled on a permit, inspected by the local code authority, and warrantied in writing. That's what \"licensed, bonded, and insured\" is supposed to mean in practice — the work is documented, signed off, and you're protected if something goes wrong."}]]}]]}]}]}],["$","section",null,{"className":"bg-bone-100/60 border-y border-ink/10 py-16 lg:py-24","children":["$","div",null,{"className":"max-w-3xl mx-auto px-6","children":[["$","p",null,{"className":"eyebrow mb-3","children":"Common questions"}],["$","h2",null,{"className":"font-display text-3xl lg:text-4xl text-ink mb-10 leading-tight","children":["Frequently asked about ","water & sewer repipes"," in Middle Tennessee."]}],["$","dl",null,{"className":"space-y-6","children":[["$","div","Do I need a whole-home repipe or just a section?",{"className":"card-press p-6","children":[["$","dt",null,{"className":"font-display text-xl text-ink mb-3","children":"Do I need a whole-home repipe or just a section?"}],["$","dd",null,{"className":"text-ink-muted leading-relaxed","children":"If you've had two or more pinhole leaks in the same year, or pressure is dropping at multiple fixtures, a full repipe usually makes more financial sense than chasing leaks. We'll diagnose honestly — spot repair when it's the right answer, full repipe only when it actually is."}]]}],["$","div","How long does a repipe take?",{"className":"card-press p-6","children":[["$","dt",null,{"className":"font-display text-xl text-ink mb-3","children":"How long does a repipe take?"}],["$","dd",null,{"className":"text-ink-muted leading-relaxed","children":"A residential supply 