f:T410,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Is a tankless water heater worth it in Middle Tennessee?","acceptedAnswer":{"@type":"Answer","text":"For homeowners staying in the house long-term, families that run out of hot water during back-to-back showers, or anyone who wants to recover the floor space a tank takes up — yes. We'll give you an honest payback estimate during the in-home quote so you can decide."}},{"@type":"Question","name":"How often does a tankless need service?","acceptedAnswer":{"@type":"Answer","text":"Once a year. A short descaling flush keeps the heat exchanger clean and the unit running efficiently. Annual service is the single biggest factor in whether a tankless makes it to its full service life."}},{"@type":"Question","name":"Do you service tankless units you didn't install?","acceptedAnswer":{"@type":"Answer","text":"Yes. We service every major brand and handle annual descaling, repairs, and warranty work on units we did not originally install."}}]}7:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.honestplumbingtn.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Services\",\"item\":\"https://www.honestplumbingtn.com/services\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Tankless Water Heater Installation & Service\",\"item\":\"https://www.honestplumbingtn.com/services/tankless-water-heaters\"}]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$f"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Service\",\"name\":\"Tankless Water Heater Installation & Service\",\"description\":\"Tankless water heater installation, annual service, and repair in Murfreesboro and across Middle Tennessee. Endless hot water, lower energy bills, and a service life that often doubles or triples a standard tank.\",\"serviceType\":\"Tankless Water Heater Installation & Service\",\"url\":\"https://www.honestplumbingtn.com/services/tankless-water-heaters\",\"provider\":{\"@id\":\"https://www.honestplumbingtn.com#business\"},\"areaServed\":[{\"@type\":\"City\",\"name\":\"Murfreesboro\"},{\"@type\":\"City\",\"name\":\"Smyrna\"},{\"@type\":\"City\",\"name\":\"La Vergne\"},{\"@type\":\"City\",\"name\":\"Nolensville\"},{\"@type\":\"City\",\"name\":\"Brentwood\"},{\"@type\":\"City\",\"name\":\"Franklin\"}]}"}}],["$","article",null,{"children":[["$","section",null,{"className":"relative h-[260px] sm:h-[340px] lg:h-[420px] overflow-hidden bg-forest-deep","children":[["$","$L4",null,{"src":"/images/work-1.jpg","alt":"Tankless water heater installed by Honest Plumbing in Middle Tennessee","fill":true,"priority":true,"sizes":"100vw","className":"object-cover opacity-80"}],["$","div",null,{"aria-hidden":true,"className":"absolute inset-0 bg-gradient-to-t from-forest-deep/70 via-forest-deep/30 to-transparent"}]]}],["$","section",null,{"className":"py-16 lg:py-24 border-b border-ink/10","children":["$","div",null,{"className":"max-w-7xl mx-auto px-6 lg:px-12 grid lg:grid-cols-12 gap-10 lg:gap-16","children":[["$","div",null,{"className":"lg:col-span-7","children":[["$","nav",null,{"aria-label":"Breadcrumb","className":"text-sm text-ink-muted mb-6","children":["$","ol",null,{"className":"flex items-center gap-2","children":[["$","li",null,{"children":["$","$L3",null,{"href":"/","className":"hover:text-forest","children":"Home"}]}],["$","li",null,{"aria-hidden":true,"children":"/"}],["$","li",null,{"children":["$","$L3",null,{"href":"/services","className":"hover:text-forest","children":"Services"}]}],["$","li",null,{"aria-hidden":true,"children":"/"}],["$","li",null,{"className":"text-ink","children":"Tankless Water Heaters"}]]}]}],["$","p",null,{"className":"eyebrow mb-4","children":"Service"}],["$","h1",null,{"className":"font-display text-4xl sm:text-5xl lg:text-6xl leading-[1.05] text-ink mb-6","children":["Tankless Water Heater Installation & Service"," ",["$","span",null,{"className":"italic text-forest","children":"in Middle Tennessee"}]]}],["$","p",null,{"className":"font-display italic text-2xl text-ink-soft mb-7","children":"Endless hot water. Lower bills. Longer service life."}],["$","p",null,{"className":"text-lg text-ink-muted leading-relaxed","children":"Tankless water heaters use less energy and less water than standard tanks, and a quality unit installed and serviced properly will commonly last two to three times as long. We install new tankless systems across Murfreesboro and the surrounding Middle Tennessee area, handle repairs and warranty work on existing units, and provide the annual service that keeps them running at full efficiency."}]]}],["$","div",null,{"className":"lg:col-span-5","children":["$","$L10",null,{"defaultService":"tankless-water-heaters"}]}]]}]}],["$","section",null,{"className":"py-16 lg:py-24","children":["$","div",null,{"className":"max-w-3xl mx-auto px-6","children":["$","div",null,{"className":"prose-editorial","children":[["$","div","Installation done right",{"children":[["$","h2",null,{"children":"Installation done right"}],["$","p",null,{"children":"Most homes converting from a tank to a tankless need three things sized correctly: the gas line, the venting, and the cold-water inlet protection. We run a properly sized gas line for the higher BTU demand of a tankless unit, install sealed concentric stainless venting, and add a scale-inhibiting filter on the inlet for Middle Tennessee's moderately hard water. The result is a clean install that meets code, passes inspection, and lasts the full design life of the unit."}]]}],["$","div","Repairs on any brand",{"children":[["$","h2",null,{"children":"Repairs on any brand"}],["$","p",null,{"children":"We repair tankless units from every major brand whether or not we installed it. Most calls are flow sensor, ignition, or scale-related — issues that resolve in a single visit once they're diagnosed correctly. If a heat exchanger has failed because the unit was never descaled, we'll quote the repair against a replacement honestly so you can decide which makes sense."}]]}],["$","div","Annual service is non-negotiable",{"children":[["$","h2",null,{"children":"Annual service is non-negotiable"}],["$","p",null,{"children":"Middle Tennessee water is moderately hard, and tankless heat exchangers scale up over time. We descale annually with a circulating flush — it takes under an hour and restores the unit's efficiency. Skip annual service for two or three years and you'll start seeing error codes, reduced flow, and eventually a heat exchanger failure that costs more than a decade of maintenance. Most customers book their service in the fall."}]]}]]}]}]}],["$","section",null,{"className":"bg-bone-100/60 border-y border-ink/10 py-16 lg:py-24","children":["$","div",null,{"className":"max-w-3xl mx-auto px-6","children":[["$","p",null,{"className":"eyebrow mb-3","children":"Common questions"}],["$","h2",null,{"className":"font-display text-3xl lg:text-4xl text-ink mb-10 leading-tight","children":["Frequently asked about ","tankless water heaters"," in Middle Tennessee."]}],["$","dl",null,{"className":"space-y-6","children":[["$","div","Is a tankless water heater worth it in Middle Tennessee?",{"className":"card-press p-6","children":[["$","dt",null,{"className":"font-display text-xl text-ink mb-3","children":"Is a tankless water heater worth it in Middle Tennessee?"}],["$","dd",null,{"className":"text-ink-muted leading-relaxed","children":"For homeowners staying in the house long-term, families that run out of hot water during back-to-back showers, or anyone who wants to recover the floor space a tank takes up — yes. We'll give you an honest payback estimate during the in-home quote so you can decide."}]]}],["$","div","How often does a tankless need service?",{"className":"card-press p-6","children":[["$","dt",null,{"className":"font-display text-xl text-ink mb-3","children":"How often does a tankless need service?"}],["$","dd",null,{"className":"text-ink-muted leading-relaxed","children":"Once a year. A short descaling flush keeps the heat exchanger clean and the unit running efficiently. Annual service is the single biggest factor in whether a tankless makes it to its full service life."}]]}],["$","div","Do you service tankless units you didn't install?",{"className":"card-press p-6","children":[["$","dt",null,{"className":"font-display text-xl text-ink mb-3","children":"Do you service tankless units you didn't install?"}],["$","dd",null,{"className":"text-ink-muted leading-relaxed","children":"Yes. We service every major brand and handle annual descaling, repairs, and warranty work on units we did not originally install."}]]}]]}]]}]}],["$","section",null,{"className":"py-16 lg:py-24","children":["$","div",null,{"className":"max-w-7xl mx-auto px-6 lg:px-12","children":[["$","div",null,{"className":"max-w-2xl mb-10","children":[["$","p",null,{"className":"eyebrow mb-3","children":"Service areas"}],["$","h2",null,{"className":"font-display text-3xl lg:text-4xl text-ink leading-tight","children":["We provide ","tankless water heaters"," across these Middle Tennessee areas:"]}]]}],["$","ul",null,{"className":"grid sm:grid-cols-2 md:grid-cols-3 gap-3","children":[["$","li","murfreesboro",{"children":["$","$L3",null,{"href":"/areas/murfreesboro","className":"block py-3 px-4 border border-ink/10 hover:border-forest hover:bg-bone-100/50 transition-colors","children":[["$","span",null,{"className":"font-semibold text-ink","children":"Murfreesboro"}],["$","span",null,{"className":"block text-xs text-ink-muted mt-0.5","children":"Rutherford County, TN"}]]}]}],["$","li","smyrna",{"children":["$","$L3",null,{"href":"/areas/smyrna","className":"block py-3 px-4 bor