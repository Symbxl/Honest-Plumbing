7:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.honestplumbingtn.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Services\",\"item\":\"https://www.honestplumbingtn.com/services\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Water Heater Repair & Installation\",\"item\":\"https://www.honestplumbingtn.com/services/water-heater-services\"}]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"How long should a water heater last?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"A standard tank heater with annual maintenance usually goes 10–13 years in Middle Tennessee. Skipping maintenance and ignoring the anode rod commonly cuts that to 7–9. Tankless units routinely make 18–22 years with proper annual service.\"}},{\"@type\":\"Question\",\"name\":\"How quickly can you replace a water heater?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"In most cases we can be on-site the same day or the next day. Standard tank replacements take a few hours start to finish, including haul-away of the old unit.\"}},{\"@type\":\"Question\",\"name\":\"Do you install recirculation pumps?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. We install and service hot-water recirculation systems so you get hot water at the faucet without the long wait — useful in larger homes or when the water heater sits far from the bathrooms.\"}}]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Service\",\"name\":\"Water Heater Repair & Installation\",\"description\":\"Gas, electric, and hybrid water heater installation, repair, and maintenance in Murfreesboro and Middle Tennessee. Recirculation pumps, anode replacement, and honest repair-vs-replace advice.\",\"serviceType\":\"Water Heater Repair & Installation\",\"url\":\"https://www.honestplumbingtn.com/services/water-heater-services\",\"provider\":{\"@id\":\"https://www.honestplumbingtn.com#business\"},\"areaServed\":[{\"@type\":\"City\",\"name\":\"Murfreesboro\"},{\"@type\":\"City\",\"name\":\"Smyrna\"},{\"@type\":\"City\",\"name\":\"La Vergne\"},{\"@type\":\"City\",\"name\":\"Nolensville\"},{\"@type\":\"City\",\"name\":\"Brentwood\"},{\"@type\":\"City\",\"name\":\"Franklin\"}]}"}}],["$","article",null,{"children":[["$","section",null,{"className":"relative h-[260px] sm:h-[340px] lg:h-[420px] overflow-hidden bg-forest-deep","children":[["$","$L4",null,{"src":"/images/work-2.jpg","alt":"Residential water heater installation by Honest Plumbing in Murfreesboro","fill":true,"priority":true,"sizes":"100vw","className":"object-cover opacity-80"}],["$","div",null,{"aria-hidden":true,"className":"absolute inset-0 bg-gradient-to-t from-forest-deep/70 via-forest-deep/30 to-transparent"}]]}],["$","section",null,{"className":"py-16 lg:py-24 border-b border-ink/10","children":["$","div",null,{"className":"max-w-7xl mx-auto px-6 lg:px-12 grid lg:grid-cols-12 gap-10 lg:gap-16","children":[["$","div",null,{"className":"lg:col-span-7","children":[["$","nav",null,{"aria-label":"Breadcrumb","className":"text-sm text-ink-muted mb-6","children":["$","ol",null,{"className":"flex items-center gap-2","children":[["$","li",null,{"children":["$","$L3",null,{"href":"/","className":"hover:text-forest","children":"Home"}]}],["$","li",null,{"aria-hidden":true,"children":"/"}],["$","li",null,{"children":["$","$L3",null,{"href":"/services","className":"hover:text-forest","children":"Services"}]}],["$","li",null,{"aria-hidden":true,"children":"/"}],["$","li",null,{"className":"text-ink","children":"Water Heaters"}]]}]}],["$","p",null,{"className":"eyebrow mb-4","children":"Service"}],["$","h1",null,{"className":"font-display text-4xl sm:text-5xl lg:text-6xl leading-[1.05] text-ink mb-6","children":["Water Heater Repair & Installation"," ",["$","span",null,{"className":"italic text-forest","children":"in Middle Tennessee"}]]}],["$","p",null,{"className":"font-display italic text-2xl text-ink-soft mb-7","children":"Hot water back on. Today, in most cases."}],["$","p",null,{"className":"text-lg text-ink-muted leading-relaxed","children":"We install and repair gas, electric, and hybrid water heaters across Murfreesboro and the surrounding Middle Tennessee area. Standard tank repairs are usually a same-day fix, and replacements are scheduled fast so you're not without hot water for long. We size the replacement to your household's real peak demand and register the manufacturer warranty before we leave."}]]}],["$","div",null,{"className":"lg:col-span-5","children":["$","$Lf",null,{"defaultService":"water-heater-services"}]}]]}]}],["$","section",null,{"className":"py-16 lg:py-24","children":["$","div",null,{"className":"max-w-3xl mx-auto px-6","children":["$","div",null,{"className":"prose-editorial","children":[["$","div","Repair or replace — an honest answer",{"children":[["$","h2",null,{"children":"Repair or replace — an honest answer"}],["$","p",null,{"children":"If your water heater is under eight years old, a repair is almost always the right call. A bad thermocouple, failed element, sticky T&P valve, or corroded anode is a straightforward fix. Past ten or twelve years, the math shifts: tanks corrode from the inside, and once you see rust in the hot water, weeping at the base, or a popping sound from sediment, replacement is the right answer. We'll tell you which category you're in."}]]}],["$","div","Gas, electric, and hybrid",{"children":[["$","h2",null,{"children":"Gas, electric, and hybrid"}],["$","p",null,{"children":"We install and service gas, electric, and heat-pump (hybrid) water heaters. Hybrid units are roughly three times as efficient as a standard electric tank and qualify for federal tax credits in many cases — they're a strong fit for homes with electric water heating that want a meaningful drop in the monthly utility bill. We'll walk you through the trade-offs honestly before you spend the money."}]]}],["$","div","Recirculation pumps and maintenance",{"children":[["$","h2",null,{"children":"Recirculation pumps and maintenance"}],["$","p",null,{"children":"If your master bath sits 40 feet from the water heater and the water runs for a minute before it's hot, a hot-water recirculation pump fixes that — instant hot water at every fixture, less water wasted down the drain. We install and service recirculation systems and also handle annual tank flushes and anode rod replacement to extend the life of the unit you already own."}]]}]]}]}]}],["$","section",null,{"className":"bg-bone-100/60 border-y border-ink/10 py-16 lg:py-24","children":["$","div",null,{"className":"max-w-3xl mx-auto px-6","children":[["$","p",null,{"className":"eyebrow mb-3","children":"Common questions"}],["$","h2",null,{"className":"font-display text-3xl lg:text-4xl text-ink mb-10 leading-tight","children":["Frequently asked about ","water heaters"," in Middle Tennessee."]}],["$","dl",null,{"className":"space-y-6","children":[["$","div","How long should a water heater last?",{"className":"card-press p-6","children":[["$","dt",null,{"className":"font-display text-xl text-ink mb-3","children":"How long should a water heater last?"}],["$","dd",null,{"className":"text-ink-muted leading-relaxed","children":"A standard tank heater with annual maintenance usually goes 10–13 years in Middle Tennessee. Skipping maintenance and ignoring the anode rod commonly cuts that to 7–9. Tankless units routinely make 18–22 years with proper annual service."}]]}],["$","div","How quickly can you replace a water heater?",{"className":"card-press p-6","children":[["$","dt",null,{"className":"font-display text-xl text-ink mb-3","children":"How quickly can you replace a water heater?"}],["$","dd",null,{"className":"text-ink-muted leading-relaxed","children":"In most cases we can be on-site the same day or the next day. Standard tank replacements take a few hours start to finish, including haul-away of the old unit."}]]}],["$","div","Do you install recirculation pumps?",{"className":"card-press p-6","children":[["$","dt",null,{"className":"font-display text-xl text-ink mb-3","children":"Do you install recirculation pumps?"}],["$","dd",null,{"className":"text-ink-muted leading-relaxed","children":"Yes. We install and service hot-water recirculation systems so you get hot water at the faucet without the long wait — useful in larger homes or when the water heater sits far from the bathrooms."}]]}]]}]]}]}],["$","section",null,{"className":"py-16 lg:py-24","children":["$","div",null,{"className":"max-w-7xl mx-auto px-6 lg:px-12","children":[["$","div",null,{"className":"max-w-2xl mb-10","children":[["$","p",null,{"className":"eyebrow mb-3","children":"Service areas"}],["$","h2",null,{"className":"font-display text-3xl lg:text-4xl text-ink leading-tight","children":["We provide ","water heaters"," across these Middle Tennessee areas:"]}]]}],["$","ul",null,{"className":"grid sm:grid-cols-2 md:grid-cols-3 gap-3","children":[["$","li","murfreesboro",{"children":["$","$L3",null,{"href":"/areas/murfreesboro","className":"block py-3 px-4 border border-ink/10 hover:border-forest hover:bg-bone-100/50 transition-colors","children":[["$","span",null,{"className":"font-semibold text-ink","children":"Murfreesboro"}],["$","span",null,{"className":"block text-xs text-ink-muted mt-0.5","children":"Rutherford County, TN"}]]}]}],["$","li","smyrna",{"children":["$","$L3",null,{"href":"/areas/smyrna","className":"block py-3 px-4 border border-ink/10 hover:border-forest hover:bg-bone-100/50 transition-colors","children":[["$","span",null,{"className":"font-semibold text-ink","children":"Smyrna"}],["$","span",null,{"className":"b