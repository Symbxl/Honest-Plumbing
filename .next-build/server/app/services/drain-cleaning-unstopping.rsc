2:Tc12,{"@context":"https://schema.org","@type":"Plumber","@id":"https://www.joebsullivanandsons.com#business","name":"Joe B. Sullivan & Sons Plumbing","legalName":"Joe B. Sullivan & Sons Plumbing Co., Inc.","description":"Family-owned commercial and residential plumbing in Nashville since 1895. Water heaters, boilers, drain cleaning, sewer & water line replacement, backflow, and gas lines. Warranty service for AO Smith, Bradford White, State Industries, and Whirlpool.","url":"https://www.joebsullivanandsons.com","telephone":"+1-615-254-8379","email":"info@joebsullivanandsons.com","priceRange":"$$","image":"https://www.joebsullivanandsons.com/og-image.png","logo":"https://www.joebsullivanandsons.com/logo.png","foundingDate":"1895-01-01","address":{"@type":"PostalAddress","streetAddress":"292 Hermitage Ave","addressLocality":"Nashville","addressRegion":"TN","postalCode":"37210","addressCountry":"US"},"geo":{"@type":"GeoCoordinates","latitude":36.1561,"longitude":-86.7707},"openingHoursSpecification":[{"@type":"OpeningHoursSpecification","dayOfWeek":"Mon","opens":"08:00","closes":"16:30"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Tue","opens":"08:00","closes":"16:30"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Wed","opens":"08:00","closes":"16:30"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Thu","opens":"08:00","closes":"16:30"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Fri","opens":"08:00","closes":"16:30"}],"areaServed":[{"@type":"City","name":"East Nashville"},{"@type":"City","name":"Downtown Nashville"},{"@type":"City","name":"Green Hills"},{"@type":"City","name":"Belle Meade & West Nashville"},{"@type":"City","name":"Brentwood"},{"@type":"City","name":"Franklin"}],"hasOfferCatalog":{"@type":"OfferCatalog","name":"Plumbing Services","itemListElement":[{"@type":"Offer","itemOffered":{"@type":"Service","name":"Water Heater Repair & Installation","url":"https://www.joebsullivanandsons.com/services/water-heater-repair-installation"}},{"@t