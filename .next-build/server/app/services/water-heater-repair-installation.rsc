e:T562,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How much does water heater installation cost in Nashville?","acceptedAnswer":{"@type":"Answer","text":"Standard tank water heater installation in the Nashville area typically runs $1,400–$2,800 fully installed, including the unit, labor, permit, haul-away of the old heater, and warranty registration. Tankless conversions run $3,500–$6,500 depending on gas line and venting requirements."}},{"@type":"Question","name":"Do you handle warranty work on AO Smith, Bradford White, State, and Whirlpool water heaters?","acceptedAnswer":{"@type":"Answer","text":"Yes — we're an authorized warranty service provider for all four manufacturers. If your water heater is still under warranty, we file the parts claim for you and turn around the repair quickly. Bring the model and serial number when you call so we can verify coverage before the truck rolls."}},{"@type":"Question","name":"How long does a water heater last in Nashville?","acceptedAnswer":{"@type":"Answer","text":"Standard tank water heaters last 10–13 years in most Nashville homes with annual maintenance (flushing the tank and checking the anode rod). Tankless units typically last 18–22 years. Hard water in some Davidson County neighborhoods shortens life by 1–3 years if the tank isn't flushed regularly."}}]}6:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.joebsullivanandsons.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Services\",\"item\":\"https://www.joebsullivanandsons.com/services\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Water Heater Repair & Installation\",\"item\":\"https://www.joebsullivanandsons.com/services/water-heater-repair-installation\"}]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$e"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Service\",\"name\":\"Water Heater Repair & Installation\",\"description\":\"Nashville's longest-running water heater specialists. Repair, replacement, and installation of gas and electric tank water heaters. Warranty service for AO Smith, Bradford White, State, and Whirlpool.\",\"serviceType\":\"Water Heater Repair & Installation\",\"url\":\"https://www.joebsullivanandsons.com/services/water-heater-repair-installation\",\"provider\":{\"@id\":\"https://www.joebsullivanandsons.com#business\"},\"areaServed\":[{\"@type\":\"City\",\"name\":\"East Nashville\"},{\"@type\":\"City\",\"name\":\"Downtown Nashville\"},{\"@type\":\"City\",\"name\":\"Green Hills\"},{\"@type\":\"City\",\"name\":\"Belle Meade & West Nashville\"},{\"@type\":\"City\",\"name\":\"Brentwood\"},{\"@type\":\"City\",\"name\":\"Franklin\"}]}"}}],["$","article",null,{"children":[["$","section",null,{"className":"relative h-[260px] sm:h-[340px] lg:h-[420px] overflow-hidden bg-forest-deep","children":[["$","$Lf",null,{"src":"https://images.unsplash.com/photo-1607472586893-edb57bdc0e39?auto=format&fit=crop&w=1600&q=70","alt":"Plumber installing a residential gas water heater — Joe B. Sullivan & Sons Plumbing, Nashville","fill":true,"priority":true,"sizes":"100vw","className":"object-cover opacity-80"}],["$","div",null,{"aria-hidden":true,"className":"absolute inset-0 bg-gradient-to-t from-forest-deep/70 via-forest-deep/30 to-transparent"}]]}],["$","section",null,{"className":"py-16 lg:py-24 border-b border-ink/10","children":["$","div",null,{"className":"max-w-7xl mx-auto px-6 lg:px-12 grid lg:grid-cols-12 gap-10 lg:gap-16","children":[["$","div",null,{"className":"lg:col-span-7","children":[["$","nav",null,{"aria-label":"Breadcrumb","className":"text-sm text-ink-muted mb-6","children":["$","ol",null,{"className":"flex items-center gap-2","children":[["$","li",null,{"children":["$","$L3",null,{"href":"/","className":"hover:text-forest","children":"Home"}]}],["$","li",null,{"aria-hidden":true,"children":"/"}],["$","li",null,{"children":["$","$L3",null,{"href":"/services","className":"hover:text-forest","children":"Services"}]}],["$","li",null,{"aria-hidden":true,"children":"/"}],["$","li",null,{"className":"text-ink","children":"Water Heaters"}]]}]}],["$","p",null,{"className":"eyebrow mb-4","children":"Service"}],["$","h1",null,{"className":"font-display text-4xl sm:text-5xl lg:text-6xl leading-[1.05] text-ink mb-6","children":["Water Heater Repair & Installation"," ",["$","span",null,{"className":"italic text-forest","children":"in Nashville"}]]}],["$","p",null,{"className":"font-display italic text-2xl text-ink-soft mb-7","children":"Hot water back on. Today, usually."}],["$","p",null,{"className":"text-lg text-ink-muted leading-relaxed","children":"Joe B. Sullivan & Sons has been Nashville's go-to water heater company since 1895. We diagnose and repair gas, electric, and high-efficiency tank water heaters every day across Davidson and Williamson counties — and when a unit isn't worth saving, we install the right replacement and haul the old one away the same visit. We're authorized warranty service for AO Smith, Bradford White, State Industries, and Whirlpool, which means most warranty parts are covered and turnaround is fast."}]]}],["$","div",null,{"className":"lg:col-span-5","children":["$","$L10",null,{"defaultService":"water-heater-repair-installation"}]}]]}]}],["$","section",null,{"className":"py-16 lg:py-24","children":["$","div",null,{"className":"max-w-3xl mx-auto px-6","children":["$","div",null,{"className":"prose-editorial","children":[["$","div","When to repair versus when to replace",{"children":[["$","h2",null,{"children":"When to repair versus when to replace"}],["$","p",null,{"children":"If your water heater is under 8 years old, the repair almost always makes sense — a bad thermocouple, a failed heating element, a corroded anode rod, or a sticky T&P valve is a $150–$450 fix, not a $1,800 replacement. Past 10–12 years on a standard tank, the math shifts: tanks corrode from the inside, and once you start seeing rust in the hot water, weeping at the base, or a popping/rumbling sound from sediment buildup, replacement is the right call. We'll tell you which category you're in honestly — including when a $200 repair will buy you another year before the inevitable replacement. Most Nashville homes we service get 10–13 years out of a quality tank heater with annual flushing."}]]}],["$","div","Brands we install — and why",{"children":[["$","h2",null,{"children":"Brands we install — and why"}],["$","p",null,{"children":"We install AO Smith, Bradford White, State Industries, Rheem, and Whirlpool tank water heaters. Bradford White is what we put in our own homes — built in Pennsylvania, available only through licensed plumbers (you can't get one at Home Depot), and our warranty failure rate is well under the industry average. AO Smith is the value play for budget-conscious replacements. State Industries (made in Ashland City, TN, right up the road) is solid for warranty work and we keep parts on the truck. Whatever you choose, we register your warranty before we leave so you don't lose coverage on a paperwork technicality."}]]}],["$","div","Sizing your replacement correctly",{"children":[["$","h2",null,{"children":"Sizing your replacement correctly"}],["$","p",null,{"children":"Most Nashville homes are under-sized on hot water. A family of four running two showers in the morning needs a 50-gallon tank minimum for a gas unit, or 65–80 gallons for electric. If you've added bathrooms, a soaking tub, or a high-flow shower head and the hot water runs out, your tank is too small — not broken. We calculate your peak demand (number of fixtures × flow rate × use period), then size the tank to that, not to whatever was there before. For homes with chronic hot-water shortages, a tankless conversion is often the better answer — see our tankless water heater page."}]]}],["$","div","Same-day service, real pricing",{"children":[["$","h2",null,{"children":"Same-day service, real pricing"}],["$","p",null,{"children":"Most water heater calls in Nashville are scheduled same-day or next-day. We'll quote a flat price after diagnosing — no surprises mid-job, no per-hour open meter. Standard tank replacements in the Nashville metro range $1,400–$2,800 installed (parts, labor, permit, haul-away of the old unit, and warranty registration), with the spread driven by tank size, gas vs. electric, and whether the install needs new water shutoffs, expansion tank, or venting work. We'll give you the number before we start."}]]}]]}]}]}],["$","section",null,{"className":"bg-bone-100/60 border-y border-ink/10 py-16 lg:py-24","children":["$","div",null,{"className":"max-w-3xl mx-auto px-6","children":[["$","p",null,{"className":"eyebrow mb-3","children":"Common questions"}],["$","h2",null,{"className":"font-display text-3xl lg:text-4xl text-ink mb-10 leading-tight","children":["Frequently asked about ","water heaters"," in Nashville."]}],["$","dl",null,{"className":"space-y-6","children":[["$","div","How much does water heater installation cost in Nashville?",{"className":"card-press p-6","children":[["$","dt",null,{"className":"font-display text-xl text-ink mb-3","children":"How much does water heater installation cost in Nashville?"}],["$","dd",null,{"className":"text-ink-muted leading-relaxed","children":"Standard tank water heater installation in the Nashville area typically runs $1,400–$2,800 fully installed, including the unit, labor, permit, haul-away of the old heater, and warranty registration. Tankless conversions run $3,500–$6,500 depending on gas line and venting requirements."}]]}],["$","div","Do you handle warranty work on AO Smith, Bradford White, State, and Whirlpool water heaters?",{"className":"card-press p-6","children":[["$","dt",null,{"className":"font-display text-xl text-ink mb-3","children":"Do you handle warranty work on AO Smith, Bradford White, State, and Whirlpool water heaters?"}],["$","dd",null,{"className":"text-ink-muted leading-relaxed","children":"Yes — we're an authorized warranty service provider for all four manufacturers. If your water heater is still under warranty, we file the parts claim for you and turn around the repair quickly. Bring the model and serial number when you call so we can verify coverage before the truck rolls."}]]}],["$","div","How long does a water heater last in Nashville?",{"className":"card-press p-6","children":[["$","dt",null,{"className":"font-display text-xl text-ink mb-3","children":"How long does a water heater last in Nashville?"}],["$","dd",null,{"className":"text-ink-muted leading-relaxed","children":"Standard tank water heaters last 10–13 years in most Nashville homes with annual maintenance (flushing the tank and checking the anode rod). Tankless units typically last 18–22 years. Hard water in some Davidson County neighborhoods shortens life by 1–3 years if the tank isn't flushed regularly."}]]}]]}]]}]}],["$","section",null,{"className":"py-16 lg:py-24","children":["$","div",null,{"className":"max-w-7xl mx-auto px-6 lg:px-12","children":[["$","div",null,{"className":"max-w-2xl mb-10","children":[["$","p",null,{"className":"eyebrow mb-3","children":"Service areas"}],["$","h2",null,{"className":"font-display text-3xl lg:text-4xl text-ink leading-tight","children":["We provide ","water heaters"," across these Nashville-area neighborhoods:"]}]]}],["$","ul",null,{"className":"grid sm:grid-cols-2 md:grid-cols-3 gap-3","children":[["$","li","east-nashville",{"children":["$","$L3",null,{"href":"/areas/east-nashville","className":"block py-3 px-4 border border-ink/10 hover:border-forest hover:bg-bone-100/50 transition-colors","children":[["$","span",null,{"className":"font-semibold text-ink","children":"East Nashville"}],["$","span",null,{"className":"block text-xs text-ink-muted mt-0.5","children":"Nashville, TN"}]]}]}],["$","li","downtown-nashville",{"children":["$","$L3",null,{"href":"/areas/downtown-nashville","className":"block py-3 px-4 border border-ink/10 hover:border-forest hover:bg-bone-100/50 transition-colors","children":[["$","span",null,{"className":"font-semibold text-ink","children":"Downtown Nashville"}],["$","span",null,{"className":"block text-xs text-ink-muted mt-0.5","children":"Nashville, TN"}]]}]}],["$","li","green-hills",{"children":["$","$L3",null,{"href":"/areas/green-hills","className":"block py-3 px-4 border border-ink/10 hover:border-forest hover:bg-bone-100/50 transition-colors","children":[["$","span",null,{"className":"font-semibold text-ink","children":"Green Hills"}],["$","span",null,{"className":"block text-xs text-ink-muted mt-0.5","children":"Nashville, TN"}]]}]}],["$","li","belle-meade",{"children":["$","$L3",null,{"href":"/areas/belle-meade","className":"block py-3 px-4 border border-ink/10 hover:border-forest hover:bg-bone-100/50 transition-colors","children":[["$","span",null,{"className":"font-semibold text-ink","children":"Belle Meade & West Nashville"}],["$","span",null,{"className":"block text-xs text-ink-muted mt-0.5","children":"Nashville, TN"}]]}]}],["$","li","brentwood",{"children":["$","$L3",null,{"href":"/areas/brentwood","className":"block py-3 px-4 border border-ink/10 hover:border-forest hover:bg-bone-100/50 transition-colors","children":[["$","span",null,{"className":"font-semibold text-ink","children":"Brentwood"}],["$","span",null,{"className":"block text-xs text-ink-muted mt-0.5","children":"Williamson County, TN"}]]}]}],["$","li","franklin",{"children":["$","$L3",null,{"href":"/areas/franklin","className":"block py-3 px-4 border border-ink/10 hover:border-forest hover:bg-bone-100/50 transition-colors","children":[["$","span",null,{"className":"font-semibold text-ink","children":"Franklin"}],["$","span",null,{"className":"block text-x