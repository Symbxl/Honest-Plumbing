xt-bone-50/60","children":"Mon–Fri 8AM–5PM · Closed Sat & Sun"}]]}]]}]]}],["$","div",null,{"className":"mt-14 pt-8 border-t border-bone-50/15 flex flex-col md:flex-row md:items-center md:justify-between gap-4 text-xs text-bone-50/55","children":[["$","p",null,{"children":["© ",2026," ","Honest Plumbing",". All rights reserved."]}],["$","p",null,{"className":"font-display italic","children":["Locally owned in ","Murfreesboro",", Tennessee · ","Service You Can Trust"]}]]}]]}]}]]}]}]]}],{"children":["blog",["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","blog","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":[["slug","how-to-find-licensed-plumber-middle-tennessee","d"],["$","$1","c",{"children":[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","blog","children","$0:f:0:1:2:children:2:children:0","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":["$L7",null,["$","$L8",null,{"children":"$L9"}]]}],{},null,false]},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","H3VwR62I0vPSWcU064lUC",{"children":[["$","$La",null,{"children":"$Lb"}],["$","$Lc",null,{"children":"$Ld"}],["$","meta",null,{"name":"next-size-adjust","content":""}]]}]]}],false]],"m":"$undefined","G":["$e","$undefined"],"s":false,"S":true}
10:I[9562,["173","static/chunks/173-c72f956e0e7ca46c.js","562","static/chunks/562-924f4ab7d671e2d3.js","953","static/chunks/app/blog/%5Bslug%5D/page-9c7cb14561192f15.js"],"LeadForm"]
f:T5d7,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How do I verify a Tennessee plumber's license?","acceptedAnswer":{"@type":"Answer","text":"Go to tn.gov/commerce/regboards/contractor and use the license lookup tool. Search by name or license number. Active licensed master plumbers in good standing appear in the database; expired, suspended, or non-existent licenses won't. The lookup is free and takes about 30 seconds."}},{"@type":"Question","name":"Do I need a permit for plumbing work in Middle Tennessee?","acceptedAnswer":{"@type":"Answer","text":"local code Codes requires permits for water heater replacement, sewer and water service line work, gas line installation, and most repipe and remodel work. Minor repairs (fixture replacement, single-fixture drain cleaning, etc.) generally don't require permits. Reputable Middle Tennessee plumbers pull the permit when one is required and include the cost in the quote."}},{"@type":"Question","name":"How much does a first-visit plumber service call cost in Middle Tennessee?","acceptedAnswer":{"@type":"Answer","text":"Most Middle Tennessee plumbing companies charge $95–$185 for the initial service call to diagnose the issue. Reputable companies (including us) apply the service call fee to the cost of the repair if you proceed. \"Free estimate\" offers are usually accompanied by inflated repair pricing — there's no free lunch, but flat pricing with a service call applied is fair."}}]}7:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.honestplumbingtn.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Insights\",\"item\":\"https://www.honestplumbingtn.com/blog\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"How to Find a Licensed Plumber in Middle Tennessee (And Avoid the Bad Ones)\",\"item\":\"https://www.honestplumbingtn.com/blog/how-to-find-licensed-plumber-middle-tennessee\"}]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$f"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"How to Find a Licensed Plumber in Middle Tennessee (And Avoid the Bad Ones)\",\"description\":\"How to find a licensed plumber in Middle Tennessee: master plumber verification, red flags, what to ask before booking, and how to avoid getting overcharged.\",\"datePublished\":\"2025-12-08\",\"dateModified\":\"2026-03-02\",\"author\":{\"@type\":\"Person\",\"name\":\"Aaron Kelly\",\"jobTitle\":\"Licensed Master Plumber, Honest Plumbing\",\"worksFor\":{\"@type\":\"Organization\",\"name\":\"Honest Plumbing\"}},\"publisher\":{\"@type\":\"Organization\",\"name\":\"Honest Plumbing\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://www.honestplumbingtn.com/logo.png\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://www.honestplumbingtn.com/blog/how-to-find-licensed-plumber-middle-tennessee\"}}"}}],["$","article",null,{"children":[["$","header",null,{"className":"py-14 lg:py-20 border-b border-ink/10","children":["$","div",null,{"className":"max-w-3xl mx-auto px-6","children":[["$","nav",null,{"aria-label":"Breadcrumb","className":"text-sm text-ink-muted mb-8","children":["$","ol",null,{"className":"flex items-center gap-2 flex-wrap","children":[["$","li",null,{"children":["$","$L3",null,{"href":"/","className":"hover:text-forest","children":"Home"}]}],["$","li",null,{"aria-hidden":true,"children":"/"}],["$","li",null,{"children":["$","$L3",null,{"href":"/blog","className":"hover:text-forest","children":"Insights"}]}],["$","li",null,{"aria-hidden":true,"children":"/"}],["$","li",null,{"className":"text-ink truncate","children":"How to Find a Licensed Plumber in Middle Tennessee (And Avoid the Bad Ones)"}]]}]}],["$","p",null,{"className":"eyebrow mb-5","children":["December 7, 2025"," · ",8," min read"," · Updated March 1, 2026"]}],["$","h1",null,{"className":"font-display text-4xl sm:text-5xl lg:text-[3.5rem] leading-[1.05] text-ink mb-7","children":"How to Find a Licensed Plumber in Middle Tennessee (And Avoid the Bad Ones)"}],["$","p",null,{"className":"text-xl text-ink-soft leading-relaxed mb-8 font-display italic","children":"There are hundreds of plumbing companies operating in Middle Tennessee. Maybe a quarter of them are who you actually want in your home. Here's how to tell which is which."}],["$","div",null,{"className":"flex items-center gap-4 pt-6 border-t border-ink/10","children":[["$","div",null,{"className":"w-11 h-11 rounded-full bg-forest text-bone-50 flex items-center justify-center font-display text-sm","children":"AK"}],["$","div",null,{"children":[["$","p",null,{"className":"text-sm font-semibold text-ink","children":"Aaron Kelly"}],["$","p",null,{"className":"text-xs text-ink-muted","children":"Licensed Master Plumber, Honest Plumbing"}]]}]]}]]}]}],["$","section",null,{"className":"py-14 lg:py-20","children":["$","div",null,{"className":"max-w-3xl mx-auto px-6","children":["$","div",null,{"className":"prose-editorial","children":[["$","div","Step 1: Verify the Tennessee master plumber license",{"children":[["$","h2",null,{"children":"Step 1: Verify the Tennessee master plumber license"}],["$","p",null,{"children":"In Tennessee, anyone doing plumbing work above a certain threshold ($25,000 in most categories) must work under a licensed master plumber. The license is issued by the Tennessee Board for Licensing Contractors, and you can look up any license at tn.gov/commerce/regboards/contractor. Active master plumbers in good standing appear in the public database; suspended, expired, or non-existent licenses don't. Honest Plumbing' master plumber on record is Aaron Kelly, license verifiable on the state board website. Any reputable Middle Tennessee plumbing company should be able to give you their master plumber's name and license number on the phone in under 30 seconds. If they can't or won't, that's a hard stop."}]]}],["$","div","Step 2: Confirm bonding and insurance",{"children":[["$","h2",null,{"children":"Step 2: Confirm bonding and insurance"}],["$","p",null,{"children":"Plumbers in Tennessee doing work above the licensing threshold are required to be bonded and insured — bonded means there's a financial guarantee for completed work that fails or isn't finished, insured means general liability and worker's comp are in place. Ask any Middle Tennessee plumber for a certificate of insurance (COI) before they start meaningful work. Reputable companies can email you a COI in 5 minutes — it's on file with their insurer. A plumber who can't produce a COI is operating without insurance, which means if their employee gets injured on your property or they damage your home doing work, you have no protection."}]]}],["$","div","Why bonding matters more than people realize",{"children":[["$","h3",null,{"children":"Why bonding matters more than people realize"}],["$","p",null,{"children":"Bonding is the financial backstop that pays you if a plumbing contractor takes your deposit, starts the work, and disappears before finishing — or if work fails inspection and the original contractor won't return to fix it. This happens more often than you'd think in plumbing, especially with door-to-door operators and unlicensed handymen. The bond is a real recovery mechanism, and reputable Middle Tennessee plumbers maintain bonding because it's the cost of being a legitimate business. A plumber operating without bonding is asking you to trust them on a handshake — sometimes that's fine, but it's an actual risk you should price into your decision."}]]}],["$","div","Step 3: Look for permits on significant work",{"children":[["$","h2",null,{"children":"Step 3: Look for permits on significant work"}],["$","p",null,{"children":"local code Codes requires plumbing permits for water heater replacements, sewer line work, water service line work, gas line installations, and most repipe and remodel work. The permit isn't a tax — it triggers an inspection by Metro Codes that verifies the work was done correctly. Reputable Middle Tennessee plumbers pull permits as a matter of routine and include the cost in the quote. Plumbers who offer to skip the permit \"to save you $75\" are also skipping the inspection, which means you have no third-party verification that the work meets code. If something fails 6 months later and there's no permit on file, you have very limited recourse."}]]}],["$","div","Step 4: Look for transparent pricing and policies",{"children":[["$","h2",null,{"children":"Step 4: Look for transparent pricing and policies"}],["$","p",null,{"children":"Reputable Middle Tennessee plumbers quote flat prices for defined scopes of work — water heater install, drain cleaning, sewer line replacement, etc. Vague pricing (\"starting at $X with no ceiling,\" or \"we'll see when we get there\") is a yellow flag, especially when combined with a service call fee that doesn't apply to the repair. Specific concerns: companies that quote a low base rate then add significant surprise charges mid-job for code-required parts, disposal fees, or \"premium service\" upcharges; companies with cancellation policies that try to charge for a quote visit if you don't proceed; companies that pressure you to commit to a repair on the spot without a written quote you can review. We provide written, flat-price quotes for every job, with everything itemized — you decide whether to proceed."}]]}],["$","div","Step 5: Read reviews the right way",{"children":[["$","h2",null,{"children":"Step 5: Read reviews the right way"}],["$","p",null,{"children":"Most established Middle Tennessee plumbing companies have abundant reviews; what matters is the pattern. Look for: more than 75 reviews (hard to fake at scale), an average above 4.5 (anything significantly lower has a real pattern problem — read the negative ones carefully), reviews spread out over time (not all clustered on the same week, which signals purchased reviews), and detailed reviews that mention specific plumbers by name, specific jobs, and specific outcomes. Avoid plumbers whose negative-review responses are defensive or attack the reviewer — the way a company responds to criticism tells you what they'll be like when something goes wrong on your job. Read the 2 and 3-star reviews specifically; the patterns there are more honest than the 5-star ones."}]]}],["$","div","The seven questions to ask before booking any Middle Tennessee plumber",{"children":[["$","h2",null,{"children":"The seven questions to ask before booking any Middle Tennessee plumber"}],["$","p",null,{"children":"Before booking with any new Middle Tennessee plumbing company, ask: (1) Who is your Tennessee-licensed master plumber, and what's the license number? (2) Are you bonded and insured? Can you email me a current certificate of insurance? (3) Is the quote going to be flat-price for a defined scope, or hourly with open-ended exposure? (4) Will the work require a Metro permit, and is the permit cost included in the quote? (5) What's the labor warranty on the install or repair? (6) Do you handle warranty work for the manufacturer of [my unit/product]? (7) When the work is complete, will I get an itemized invoice for my records and insurance? Honest Plumbing answers yes/specifics to all seven, with documentation. If a Middle Tennessee plumber can't or won't answer any of these directly, that's your answer."}]]}],["$","div","Red flags when choosing a Middle Tennessee plumber",{"children":[["$","h2",null,{"children":"Red flags when choosing a Middle Tennessee plumber"}],["$","p",null,{"children":"Walk away from any Middle Tennessee plumbing company that: can't or won't give you their Tennessee master plumber license number, requires cash-only payment, refuses to provide a written quote before starting work, pressures you to commit on the spot without time to review the quote, claims a permit isn't needed for work that clearly requires one, refuses to provide proof of insurance, sells you on \"premium\" service tiers without explaining what's actually different, or whose pricing is dramatically below market without a clear explanation. Middle Tennessee has plenty of legitimate plumbing companies at every price point — you don't need to compromise on basics like licensing, insurance, or transparent pricing."}]]}]]}]}]}],["$","section",null,{"className":"bg-bone-100/60 border-y border-ink/10 py-14 lg:py-20","children":["$","div",null,{"className":"max-w-3xl mx-auto px-6","children":[["$","p",null,{"className":"eyebrow mb-3","children":"Quick answers"}],["$","h2",null,{"className":"font-display text-3xl text-ink mb-9 leading-tight","children":"Frequently asked."}],["$","dl",null,{"className":"space-y-5","children":[["$","div","How do I verify a Tennessee plumber's license?",{"className":"card-press p-6","children":[["$","dt",null,{"className":"font-display text-lg text-ink mb-3","children":"How do I verify a Tennessee plumber's license?"}],["$","dd",null,{"className":"text-ink-muted leading-relaxed","children":"Go to tn.gov/commerce/regboards/contractor and use the license lookup tool. Search by name or license number. Active licensed master plumbers in good standing appear in the database; expired, suspended, or non-existent licenses won't. The lookup is free and takes about 30 seconds."}]]}],["$","div","Do I need a permit for plumbing work in Middle Tennessee?",{"className":"card-press p-6","children":[["$","dt",null,{"className":"font-display text-lg text-ink mb-3","children":"Do I need a permit for plumbing work in Middle Tennessee?"}],["$","dd",null,{"className":"text-ink-muted leading-relaxed","children":"local code Codes requires permits for water heater replacement, sewer and water service line work, gas line installation, and most repipe and remodel work. Minor repairs (fixture replacement, single-fixture drain cleaning, etc.) generally don't require permits. Reputable Middle Tennessee plumbers pull the permit when one is required and include the cost in the quote."}]]}],["$","div","How much does a first-visit plumber service call cost in Middle Tennessee?",{"className":"card-press p-6","children":[["$","dt",null,{"className":"font-display text-lg text-ink mb-3","children":"How much does a first-visit plumber service call cost in Middle Tennessee?"}],["$","dd",null,{"className":"text-ink-muted leading-relaxed","children":"Most Middle Tennessee plumbing companies charge $95–$185 for the initial service call to diagnose the issue. Reputable companies (including us) apply the service call fee to the cost of the repair if you proceed. \"Free estimate\" offers are usually accompanied by inflated repair pricing — there's no free lunch, but flat pricing with a service call applied is fair."}]]}]]}]]}]}],["$","section",null,{"className":"py-14 lg:py-20 border-b border-ink/10","children":["$","div",null,{"className":"max-w-4xl mx-auto px-6","children":["$","div",null,{"className":"grid md:grid-cols-2 gap-10","children":[["$","div",null,{"children":[["$","p",null,{"className":"eyebrow mb-4","children":"Related services"}],["$","ul",null,{"className":"space-y-2","children":[["$","li","water-heater-services",{"children":["$","$L3",null,{"href":"/services/water-heater-services","className":"block py-3 px-4 border border-ink/10 hover:border-forest hover:bg-bone-100/50 transition-colors","children":[["$","span",null,{"className":"font-semibold text-ink","children":"Water Heater Repair & Installation"}],["$","span",null,{"className":"block text-xs text-ink-muted mt-0.5","children":"Hot water back on. Today, in most cases."}]]}]}],["$","li","sewers-and-drains",{"children":["$","$L3",null,{"href":"/services/sewers-and-drains","className":"block py-3 px-4 border border-ink/10 hover:border-forest hover:bg-bone-100/50 transition-colors","children":[["$","span",null,{"className":"font-semibold text-ink","children":"Sewer & Drain Services"}],["$","span",null,{"className":"block text-xs text-ink-muted mt-0.5","children":"Clog cleared. Line camera-inspected. Honest answer next."}]]}]}],["$","li","water-sewer-repipes",{"children":["$","$L3",null,{"href":"/services/water-sewer-repipes","className":"block py-3 px-4 border border-ink/10 hover:border-forest hover:bg-bone-100/50 transition-colors","children":[["$","span",null,{"className":"font-semibold text-ink","children":"Water & Sewer Repipes"}],["$","span",null,{"className":"block text-xs text-ink-muted mt-0.5","children":"Whole-home repipes. Permitted, inspected, warrantied."}]]}]}],["$","li","water-sewer-repipes",{"children":["$","$L3",null,{"href":"/services/water-sewer-repipes","className":"block py-3 px-4 border border-ink/10 hover:border-forest hover:bg-bone-100/50 transition-colors","children":[["$","span",null,{"className":"font-semibold text-ink","children":"Water & Sewer Repipes"}],["$","span",null,{"className":"block text-xs text-ink-muted mt-0.5","children":"Whole-home repipes. Permitted, inspected, warrantied."}]]}]}]]}]]}],["$","div",null,{"children":[["$","p",null,{"className":"eyebrow mb-4","children":"Related service areas"}],["$","ul",null,{"className":"space-y-2","children":[["$","li","murfreesboro",{"children":["$","$L3",null,{"href":"/areas/murfreesboro","className":"block py-3 px-4 border border-ink/10 hover:border-forest hover:bg-bone-100/50 transition-colors","children":[["$","span",null,{"className":"font-semibold text-ink","children":"Murfreesboro"}],["$","span",null,{"className":"block text-xs text-ink-muted mt-0.5","children":["Rutherford County, TN"," · ","37127, 37128, 37129, 37130"]}]]}]}],["$","li","murfreesboro",{"children":["$","$L3",null,{"href":"/areas/murfreesboro","className":"block py-3 px-4 border border-ink/10 hover:border-forest hover:bg-bone-100/50 transition-c