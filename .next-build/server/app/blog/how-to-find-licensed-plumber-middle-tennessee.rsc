2:Td14,{"@context":"https://schema.org","@type":"Plumber","@id":"https://www.honestplumbingtn.com#business","name":"Honest Plumbing","legalName":"Honest Plumbing","description":"Honest, licensed residential plumbing in Murfreesboro and across Middle Tennessee. Tankless and tank water heaters, sewer and drain service, water filtration, kitchen and bath plumbing, and full water and sewer repipes. Owned by master plumber Aaron Kelly — fair pricing, honest consultation, and clean work every visit.","url":"https://www.honestplumbingtn.com","telephone":"+1-615-962-7007","email":"honestplumbingtn@gmail.com","priceRange":"$$","image":"https://www.honestplumbingtn.com/og-image.png","logo":"https://www.honestplumbingtn.com/logo.png","foundingDate":"2013-01-01","address":{"@type":"PostalAddress","streetAddress":"","addressLocality":"Murfreesboro","addressRegion":"TN","postalCode":"37130","addressCountry":"US"},"geo":{"@type":"GeoCoordinates","latitude":35.8628845,"longitude":-86.5142059},"openingHoursSpecification":[{"@type":"OpeningHoursSpecification","dayOfWeek":"Mon","opens":"08:00","closes":"17:00"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Tue","opens":"08:00","closes":"17:00"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Wed","opens":"08:00","closes":"17:00"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Thu","opens":"08:00","closes":"17:00"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Fri","opens":"08:00","closes":"17:00"}],"areaServed":[{"@type":"City","name":"Murfreesboro"},{"@type":"City","name":"Smyrna"},{"@type":"City","name":"La Vergne"},{"@type":"City","name":"Nolensville"},{"@type":"City","name":"Brentwood"},{"@type":"City","name":"Franklin"}],"hasOfferCatalog":{"@type":"OfferCatalog","name":"Plumbing Services","itemListElement":[{"@type":"Offer","itemOffered":{"@type":"Service","name":"Tankless Water Heater Installation & Service","url":"https://www.honestplumbingtn.com/services/tankless-water-heaters"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Water Heater Repair & Installation","url":"https://www.honestplumbingtn.com/services/water-heater-services"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Sewer & Drain Services","url":"https://www.honestplumbingtn.com/services/sewers-and-drains"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Whole-House Water Filtration","url":"https://www.honestplumbingtn.com/services/water-filtration"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Kitchen Plumbing","url":"https://www.honestplumbingtn.com/services/kitchen-plumbing"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Bathroom Plumbing","url":"https://www.honestplumbingtn.com/services/bathroom-plumbing"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Water & Sewer Repipes","url":"https://www.honestplumbingtn.com/services/water-sewer-repipes"}}]},"aggregateRating":{"@type":"AggregateRating","ratingValue":5,"reviewCount":42,"bestRating":5,"worstRating":1},"sameAs":["https://www.facebook.com/honestplumbingtn/","https://www.google.com/maps/place/Honest+Plumbing/@35.8628845,-86.5163946,17z/data=!3m1!4b1!4m5!3m4!1s0x8863f54ca952eb6b:0x71069bcd06dfc385!8m2!3d35.8628845!4d-86.5142059","https://www.yelp.com/biz/honest-plumbing-murfreesboro","https://www.expertise.com/tn/murfreesboro/plumbing#HonestPlumbing"]}0:{"P":null,"b":"kOA6iVbi0oXGntEWihQQ5","p":"","c":["","blog","how-to-find-licensed-plumber-middle-tennessee"],"i":false,"f":[[["",{"children":["blog",{"children":[["slug","how-to-find-licensed-plumber-middle-tennessee","d"],{"children":["__PAGE__",{}]}]}]},"$undefined","$undefined",true],["",["$","$1","c",{"children":[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/71a88392d30e54eb.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","html",null,{"lang":"en","className":"__variable_9c342d","children":["$","body",null,{"children":[["$","a",null,{"href":"#main","className":"skip-link","children":"S