2:Td14,{"@context":"https://schema.org","@type":"Plumber","@id":"https://www.honestplumbingtn.com#business","name":"Honest Plumbing","legalName":"Honest Plumbing","description":"Honest, licensed residential plumbing in Murfreesboro and across Middle Tennessee. Tankless and tank water heaters, sewer and drain service, water filtration, kitchen and bath plumbing, and full water and sewer repipes. Owned by master plumber Aaron Kelly — fair pricing, honest consultation, and clean work every visit.","url":"https://www.honestplumbingtn.com","telephone":"+1-615-962-7007","email":"honestplumbingtn@gmail.com","priceRange":"$$","image":"https://www.honestplumbingtn.com/og-image.png","logo":"https://www.honestplumbingtn.com/logo.png","foundingDate":"2013-01-01","address":{"@type":"PostalAddress","streetAddress":"","addressLocality":"Murfreesboro","addressRegion":"TN","postalCode":"37130","addressCountry":"US"},"geo":{"@type":"GeoCoordinates","latitude":35.8628845,"longitude":-86.5142059},"openingHoursSpecification":[{"@type":"OpeningHoursSpecification","dayOfWeek":"Mon","opens":"08:00","closes":"17:00"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Tue","opens":"08:00","closes":"17:00"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Wed","opens":"08:00","closes":"17:00"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Thu","opens":"08:00","closes":"17:00"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Fri","opens":"08:00","closes":"17:00"}],"areaServed":[{"@type":"City","name":"Murfreesboro"},{"@type":"City","name":"Smyrna"},{"@type":"City","name":"La Vergne"},{"@type":"City","name":"Nolensville"},{"@type":"City","name":"Brentwood"},{"@type":"City","name":"Franklin"}],"hasOfferCatalog":{"@type":"OfferCatalog","name":"Plumbing Services","itemListElement":[{"@type":"Offer","itemOffered":{"@type":"Service","name":"Tankless Water Heater Installation & Service","url":"https://www.honestplumbingtn.com/services/tankless-water-heaters"}},{"@type":"Offer","itemOffered":{"@