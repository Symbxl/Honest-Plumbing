2:Tc12,{"@context":"https://schema.org","@type":"Plumber","@id":"https://www.joebsullivanandsons.com#business","name":"Joe B. Sullivan & Sons Plumbing","legalName":"Joe B. Sullivan & Sons Plumbing Co., Inc.","description":"Family-owned commercial and residential plumbing in Nashville since 1895. Water heaters, boilers, drain cleaning, sewer & water line replacement, backflow, and gas lines. Warranty service for AO Smith, Bradford White, State Industries, and Whirlpool.","url":"https://www.joebsullivanandsons.com","telephone":"+1-615-254-8379","email":"info@joebsullivanandsons.com","priceRange":"$$","image":"https://www.joebsullivanandsons.com/og-image.png","logo":"https://www.joebsullivanandsons.com/logo.png","foundingDate":"1895-01-01","address":{"@type":"PostalAddress","streetAddress":"292 Hermitage Ave","addressLocality":"Nashville","addressRegion":"TN","postalCode":"37210","addressCountry":"US"},"geo":{"@type":"GeoCoordinates","latitude":36.1561,"longitude":-86.7707},"openingHoursSpecification":[{"@type":"OpeningHoursSpecification","dayOfWeek":"Mon","opens":"08:00","closes":"16:30"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Tue","opens":"08:00","closes":"16:30"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Wed","opens":"08:00","closes":"16:30"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Thu","opens":"08:00","closes":"16:30"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Fri","opens":"08:00","closes":"16:30"}],"areaServed":[{"@type":"City","name":"East Nashville"},{"@type":"City","name":"Downtown Nashville"},{"@type":"City","name":"Green Hills"},{"@type":"City","name":"Belle Meade & West Nashville"},{"@type":"City","name":"Brentwood"},{"@type":"City","name":"Franklin"}],"hasOfferCatalog":{"@type":"OfferCatalog","name":"Plumbing Services","itemListElement":[{"@type":"Offer","itemOffered":{"@type":"Service","name":"Water Heater Repair & Installation","url":"https://www.joebsullivanandsons.com/services/water-heater-repair-installation"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Tankless Water Heater Installation & Repair","url":"https://www.joebsullivanandsons.com/services/tankless-water-heaters"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Commercial Plumbing & Boiler Service","url":"https://www.joebsullivanandsons.com/services/commercial-plumbing"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Drain Cleaning & Unstopping","url":"https://www.joebsullivanandsons.com/services/drain-cleaning-unstopping"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Sewer & Water Line Replacement","url":"https://www.joebsullivanandsons.com/services/sewer-water-line-replacement"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Backflow & Gas Line Service","url":"https://www.joebsullivanandsons.com/services/backflow-gas-lines"}}]},"aggregateRating":{"@type":"AggregateRating","ratingValue":4.9,"reviewCount":187,"bestRating":5,"worstRating":1},"sameAs":["https://www.facebook.com/SullivanJoeBSonsPlumbing","https://maps.google.com/?q=Joe+B+Sullivan+Sons+Plumbing+Nashville"]}0:{"P":null,"b":"-B_Rsj-tD-dSSMY7zNYmx","p":"","c":["","blog","signs-you-need-plumber-nashville"],"i":false,"f":[[["",{"children":["blog",{"children":[["slug","signs-you-need-plumber-nashville","d"],{"children":["__PAGE__",{}]}]}]},"$undefined","$undefined",true],["",["$","$1","c",{"children":[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/c5a994aedd87f436.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","html",null,{"lang":"en","className":"__variable_9c342d","children":["$","body",null,{"children":[["$","a",null,{"href":"#main","className":"skip-link","children":"Skip to main content"}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","header",null,{"className":"sticky top-0 z-30 backdrop-blur-md bg-bone-50/85 border-b border-ink/10","children":["$","div",null,{"className":"max-w-7xl mx-auto p