6:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.joebsullivanandsons.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Service Areas\",\"item\":\"https://www.joebsullivanandsons.com/areas\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Green Hills\",\"item\":\"https://www.joebsullivanandsons.com/areas/green-hills\"}]}"}}],["$","article",null,{"children":[["$","section",null,{"className":"py-16 lg:py-24 border-b border-ink/10","children":["$","div",null,{"className":"max-w-7xl mx-auto px-6 lg:px-12 grid lg:grid-cols-12 gap-10 lg:gap-16","children":[["$","div",null,{"className":"lg:col-span-7","children":[["$","nav",null,{"aria-label":"Breadcrumb","className":"text-sm text-ink-muted mb-6","children":["$","ol",null,{"className":"flex items-center gap-2","children":[["$","li",null,{"children":["$","$L3",null,{"href":"/","className":"hover:text-forest","children":"Home"}]}],["$","li",null,{"aria-hidden":true,"children":"/"}],["$","li",null,{"children":["$","$L3",null,{"href":"/areas","className":"hover:text-forest","children":"Service Areas"}]}],["$","li",null,{"aria-hidden":true,"children":"/"}],["$","li",null,{"className":"text-ink","children":"Green Hills"}]]}]}],["$","p",null,{"className":"eyebrow mb-4","children":["Nashville, TN"," · ","37215 · 37205"]}],["$","h1",null,{"className":"font-display text-4xl sm:text-5xl lg:text-6xl leading-[1.05] text-ink mb-6","children":["Plumber in"," ",["$","span",null,{"className":"italic text-forest","children":"Green Hills"}]]}],["$","p",null,{"className":"font-display italic text-2xl text-ink-soft mb-7","children":["On-site in 15–25 minutes from our shop","."]}],["$","p",null,{"className":"text-lg text-ink-muted leading-relaxed","children":"Green Hills and the surrounding 37215 zip is one of our steadiest service areas — a mix of postwar ranches, larger 1980s–2000s builds, and significant ongoing remodeling. The work we do there leans residential: water heater replacements, remodel plumbing, sewer line camera inspections during real estate transactions, and the occasional tankless conversion for homeowners who've finally gotten tired of running out of hot water during teenager-shower hour."}]]}],["$","div",null,{"className":"lg:col-span-5","children":["$","$Le",null,{}]}]]}]}],["$","section",null,{"className":"py-16 lg:py-24","children":["$","div",null,{"className":"max-w-3xl mx-auto px-6","children":[["$","p",null,{"className":"eyebrow mb-3","children":["What we see in ","Green Hills"]}],["$","h2",null,{"className":"font-display text-3xl lg:text-4xl text-ink mb-7 leading-tight","children":["The plumbing reality of ","Green Hills","."]}],["$","div",null,{"className":"prose-editorial","children":["$","p",null,{"children":"Green Hills, Forest Hills, and Hillsboro-West End share a housing pattern: significant land area, mature trees, and homes ranging from 1940s ranches up through current new construction. The mature trees mean sewer lateral root intrusion is a constant concern — many of these 1950s clay laterals are at the end of their life, and we do a steady volume of camera inspections and trenchless replacements. The larger homes also tend to have under-sized water heaters relative to demand (multi-bath households with soaking tubs and high-flow showers), and we do a lot of upsize replacements and tankless conversions. Remodeling activity is constant, and we work with several local GCs on rough-in and trim-out plumbing."}]}]]}]}],["$","section",null,{"className":"bg-bone-100/60 border-y border-ink/10 py-16 lg:py-24","children":["$","div",null,{"className":"max-w-4xl mx-auto px-6","children":[["$","p",null,{"className":"eyebrow mb-3","children":["Green Hills"," plumbing patterns"]}],["$","h2",null,{"className":"font-display text-3xl lg:text-4xl text-ink mb-10 leading-tight