6:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.joebsullivanandsons.com/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Service Areas\",\"item\":\"https://www.joebsullivanandsons.com/areas\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Belle Meade & West Nashville\",\"item\":\"https://www.joebsullivanandsons.com/areas/belle-meade\"}]}"}}],["$","article",null,{"children":[["$","section",null,{"className":"relative h-[260px] sm:h-[340px] lg:h-[420px] overflow-hidden bg-forest-deep","children":[["$","$Le",null,{"src":"https://images.unsplash.com/photo-1606762903097-713bf356b8c2?auto=format&fit=crop&w=1600&q=70","alt":"Belle Meade and West Nashville — upscale residential plumbing service area","fill":true,"priority":true,"sizes":"100vw","className":"object-cover opacity-80"}],["$","div",null,{"aria-hidden":true,"className":"absolute inset-0 bg-gradient-to-t from-forest-deep/70 via-forest-deep/30 to-transparent"}]]}],["$","section",null,{"className":"py-16 lg:py-24 border-b border-ink/10","children":["$","div",null,{"className":"max-w-7xl mx-auto px-6 lg:px-12 grid lg:grid-cols-12 gap-10 lg:gap-16","children":[["$","div",null,{"className":"lg:col-span-7","children":[["$","nav",null,{"aria-label":"Breadcrumb","className":"text-sm text-ink-muted mb-6","children":["$","ol",null,{"className":"flex items-center gap-2","children":[["$","li",null,{"children":["$","$L3",null,{"href":"/","className":"hover:text-forest","children":"Home"}]}],["$","li",null,{"aria-hidden":true,"children":"/"}],["$","li",null,{"children":["$","$L3",null,{"href":"/areas","className":"hover:text-forest","children":"Service Areas"}]}],["$","li",null,{"aria-hidden":true,"children":"/"}],["$","li",null,{"className":"text-ink","children":"Belle Meade & West Nashville"}]]}]}],["$","p",null,{"className":"eyebrow mb-4","children":["Nashville, TN"," · ","37205 · 37209 · 37221"]}],["$","h1",null,{"className":"font-display text-4xl sm:text-5xl lg:text-6xl leading-[1.05] text-ink mb-6","children":["Plumber in"," ",["$","span",null,{"className":"italic text-forest","children":"Belle Meade & West Nashville"}]]}],["$","p",null,{"className":"font-display italic text-2xl text-ink-soft mb-7","children":["On-site in 20–30 minutes from our shop","."]}],["$","p",null,{"className":"text-lg text-ink-muted leading-relaxed","children":"We do a lot of work in Belle Meade, Sylvan Park, West Meade, and out into Bellevue. Belle Meade homes tend to be larger, on bigger lots, with more elaborate plumbing systems — multiple water heaters, recirculation pumps, exterior irrigation backflow, pool and pool-house plumbing — and they reward a plumber who's seen all of that before. Sylvan Park's 1920s–1940s bungalows have a lot in common with East Nashville's heritage stock; the failure patterns and our service approach are similar."}]]}],["$","div",null,{"className":"lg:col-span-5","children":["$","$Lf",null,{}]}]]}]}],["$","section",null,{"className":"py-16 lg:py-24","children":["$","div",null,{"className":"max-w-3xl mx-auto px-6","children":[["$","p",null,{"className":"eyebrow mb-3","children":["What we see in ","Belle Meade & West Nashville"]}],["$","h2",null,{"className":"font-display text-3xl lg:text-4xl text-ink mb-7 leading-tight","children":["The plumbing reality of ","Belle Meade & West Nashville","."]}],["$","div",null,{"className":"prose-editorial","children":["$","p",null,{"children":"Belle Meade is the high end of Nashville residential plumbing: large estates, multiple water heaters, recirculating hot water loops, geothermal and multi-system HVAC interactions with plumbing, and significant exterior plumbing (pool, fountain, irrigation backflow). These homes need a plumber who can size for actual peak demand, not whatever spec the original installer used. Sylvan Park's older bungalow stock — much of it 1920s–1940s — has the same galvanized supply line and cast iron drain issues as East Nashville heritage homes. West Meade and Bellevue skew newer (1970s–2000s) with more straightforward residential service needs. We work all four areas regularly."}]}]]}]}],["$","section",null,{"className":"bg-bone-100/60 border-y border-ink/10 py-16 lg:py-24","children":["$","div",null,{"className":"max-w-4xl mx-auto px-6","children":[["$","p",null,{"className":"eyebrow mb-3","children":["Belle Meade & West Nashville"," plumbing patterns"]}],["$","h2",null,{"className":"font-display text-3xl lg:text-4xl text-ink mb-10 leading-tight","children":["Common issues we handle in"," ",["$","span",null,{"className":"italic text-forest","children":"Belle Meade & West Nashville"}],"."]}],["$","ul",null,{"className":"space-y-4","children":[["$","li","Multi-zone hot water recirculation troubleshooting in larger homes",{"className":"card-press p-5 flex gap-5 items-start","children":[["$","span",null,{"className":"font-display text-sm text-copper-deep tracking-[0.2em] shrink-0 pt-1","children":"01"}],["$","span",null,{"className":"text-ink leading-relaxed","children":"Multi-zone hot water recirculation troubleshooting in larger homes"}]]}],["$","li","Irrigation and pool backflow installation and annual testing",{"className":"card-press p-5 flex gap-5 items-start","children":[["$","span",null,{"className":"font-display text-sm text-copper-deep tracking-[0.2em] shrink-0 pt-1","children":"02"}],["$","span",null,{"className":"text-ink leading-relaxed","children":"Irrigation and pool backflow installation and annual testing"}]]}],["$","li","Galvanized supply line replacement in Sylvan Park bungalows",{"className":"card-press p-5 flex gap-5 items-start","children":[["$","span",null,{"className":"font-display text-sm text-copper-deep tracking-[0.2em] shrink-0 pt-1","children":"03"}],["$","span",null,{"className":"text-ink leading-relaxed","children":"Galvanized supply lin